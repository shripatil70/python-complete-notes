# Python Data Types

# Integer
a = 10
print(type(a))

# Float
b = 10.5
print(type(b))

# String
c = "Hello Python"
print(type(c))

# Boolean
d = True
print(type(d))

# List
my_list = [1,2,3,4]
print(type(my_list))

# Tuple
my_tuple = (1,2,3)
print(type(my_tuple))

# Set
my_set = {1,2,3}
print(type(my_set))

# Dictionary
my_dict = {"name":"John","age":25}
print(type(my_dict))
